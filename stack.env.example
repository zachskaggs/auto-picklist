# Portainer Stack Environment Variables (example)
HOST_PORT=8000
SESSION_SECRET=change-me
SETTINGS_PIN=1234
MANAPOOL_EMAIL=
MANAPOOL_ACCESS_TOKEN=
MANAPOOL_BASE_URL=https://manapool.com/api/v1
MANAPOOL_RECENT_MINUTES=10
MANAPOOL_MAX_WORKERS=8
MANAPOOL_INVENTORY_WORKERS=12
SCRYFALL_MAX_WORKERS=8
BASIC_AUTH_USER=
BASIC_AUTH_PASS=
# CardKingdom buylist
CARDKINGDOM_BASE_URL=https://api.cardkingdom.com
CK_BUYLIST_MIN_RATIO=0.75
# Delisting runs at CardKingdom batch CREATION, not on pick.
# 0 = dry-run (log intended delists only); 1 = real ManaPool delist at batch creation
MANAPOOL_INVENTORY_WRITE=0
