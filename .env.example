HOST_PORT=8000
# App
APP_HOST=0.0.0.0
APP_PORT=8000
DB_PATH=data/app.db
SESSION_SECRET=change-me
SETTINGS_PIN=1234
BASIC_AUTH_USER=
BASIC_AUTH_PASS=
MANAPOOL_RECENT_MINUTES=10
MANAPOOL_MAX_WORKERS=8

# ManaPool
MANAPOOL_BASE_URL=https://manapool.com/api/v1
MANAPOOL_EMAIL=
MANAPOOL_ACCESS_TOKEN=
MANAPOOL_MAX_RETRIES=3
MANAPOOL_TIMEOUT_SECONDS=20

# Scryfall
SCRYFALL_BASE_URL=https://api.scryfall.com
SCRYFALL_IMAGE_SIZE=normal
SCRYFALL_MAX_WORKERS=8
# Scryfall requires a non-default, identifying User-Agent (and an Accept header);
# requests without one are rejected with HTTP 400 (generic_user_agent).
SCRYFALL_USER_AGENT=auto-picklist/1.0 (+https://manapool.com)

# CardKingdom buylist
CARDKINGDOM_BASE_URL=https://api.cardkingdom.com
CK_BUYLIST_MIN_RATIO=0.75
# ManaPool inventory writes (delist a card from ManaPool when picked in a
# CardKingdom batch). 0 = dry-run (log only, no marketplace change), 1 = real writes.
MANAPOOL_INVENTORY_WRITE=0

